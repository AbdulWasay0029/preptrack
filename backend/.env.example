# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/preptrack

# Server
PORT=3001
NODE_ENV=development

# Auth — shared secret between bot and backend for internal API calls
INTERNAL_API_SECRET=change_this_to_a_random_string_min_32_chars

# Razorpay — get from razorpay.com dashboard
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Telegram — used for verifying Telegram Login Widget sessions on the web
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
